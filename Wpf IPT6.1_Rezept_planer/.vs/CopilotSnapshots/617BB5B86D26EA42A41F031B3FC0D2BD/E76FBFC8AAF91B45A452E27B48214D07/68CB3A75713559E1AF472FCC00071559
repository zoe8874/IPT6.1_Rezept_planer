        private void Button_Click(object sender, RoutedEventArgs e)
        {
            var text = SearchTextBox.Text?.Trim();
            if (string.IsNullOrEmpty(text))
                return;

            if (!IngredientsListBox.Items.Contains(text))
            {
                IngredientsListBox.Items.Add(text);
            }

            SearchTextBox.Clear();
            SearchTextBox.Focus();
        }

