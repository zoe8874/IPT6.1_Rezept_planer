<Window x:Class="Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wpf"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel>
   
        <Grid DockPanel.Dock="Top" Height="60" Background="#4cBB17">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Recipe Planner" Foreground="White" VerticalAlignment="Center" Margin="12,0" FontSize="18" FontWeight="Bold"/>

            <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            
            <Border Grid.Column="0" Background="#FFF7F7F7" BorderBrush="#FFCCCCCC" BorderThickness="1" Margin="10" CornerRadius="6">
                <StackPanel Margin="12">
                    <TextBlock Text="Navigation" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Button Content="Recipes" Margin="0,4" Style="{StaticResource RoundedButtonStyle}"/>
                    <Button x:Name="MyFirgeButton" Content="My Fridge" Margin="0,4" Style="{StaticResource RoundedButtonStyle}" Click="MyFirgeButton_Click"/>
                    <Button Content="Shopping List" Margin="0,4" Style="{StaticResource RoundedButtonStyle}"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="10"/>
        </Grid>
    </DockPanel>
</Window>


